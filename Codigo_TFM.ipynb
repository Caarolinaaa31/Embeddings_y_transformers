        "\n",
        "    # Cargamos el modelo\n",
        "    #w2v_model = Word2Vec.load(ruta_w2v_model)\n",
        "\n",
        "    # Cargamos las matrices\n",
        "    X_train_w2v = np.load(ruta_train_w2v)\n",
        "    X_test_w2v = np.load(ruta_test_w2v)\n",
        "    X_train_w2v_scaled = np.load(ruta_train_w2v_scaled)\n",
        "    X_test_w2v_scaled = np.load(ruta_test_w2v_scaled)\n",
        "\n",
        "    t_emb_w2v = 3.78 # EDITADO POR MÍ\n",
        "    mem_emb_w2v = 3819.23\n",
        "\n",
        "    print(f\"Dimensiones X_train_w2v: {X_train_w2v.shape}\")\n",
        "\n",
        "else:\n",
        "    print(\"--- ENTRENANDO WORD2VEC ---\")\n",
        "    t0_emb = time()\n",
        "    mem0_emb = get_memory()\n",
        "\n",
        "    # Tokenización\n",
        "    X_train_tokens = [text.split() for text in X_train_clean]\n",
        "    X_test_tokens = [text.split() for text in X_test_clean]\n",
        "\n",
        "    # Entrenar modelo Word2Vec: vectores de dimensión 300. Ventana de 5 palabras. Palabras que aparecen >5 veces.\n",
        "    w2v_model = Word2Vec(sentences=X_train_tokens,\n",
        "                         vector_size=300,\n",
        "                         window=5,\n",
        "                         min_count=5,\n",
        "                         workers=4)\n",
        "\n",
        "    # Entrenamos un TF-IDF solo para extraer la métrica IDF de cada palabra\n",
        "    tfidf_w2v = TfidfVectorizer(\n",
        "        tokenizer=lambda x: x.split(), # Usamos el mismo split() que en Word2Vec\n",
        "        token_pattern=None,            # Desactivamos el patrón por defecto para que no interfiera\n",
        "        lowercase=False\n",
        "    )\n",
        "\n",
        "    # Entrenamos\n",
        "    tfidf_w2v.fit(X_train_clean)\n",
        "\n",
        "    # Creamos el diccionario de pesos\n",
        "    word2weight = {word: tfidf_w2v.idf_[i] for word, i in tfidf_w2v.vocabulary_.items()}\n",
        "\n",
        "    # Verifica que los tokens están en el diccionario y promedia los vectores para representar el paper\n",
        "    def document_vector_weighted(word2vec_model, doc_tokens, weight_dict):\n",
        "        # Filtramos palabras que estén tanto en Word2Vec como en nuestro diccionario de pesos\n",
        "        valid_words = [word for word in doc_tokens if word in word2vec_model.wv.key_to_index and word in weight_dict]\n",
        "        if not valid_words:\n",
        "            return np.zeros(word2vec_model.vector_size)\n",
        "\n",
        "        # Extraemos los vectores de las palabras válidas\n",
        "        vectors = word2vec_model.wv[valid_words]\n",
        "        # Extraemos los pesos correspondientes a esas palabras\n",
        "        weights = np.array([weight_dict[word] for word in valid_words])\n",
        "        # Calculamos el promedio ponderado (suma(vector * peso) / suma(pesos))\n",
        "        weighted_avg = np.average(vectors, axis=0, weights=weights)\n",
        "\n",
        "        return weighted_avg\n",
        "\n",
        "    # Generar los embeddings ponderados\n",
        "    X_train_w2v = np.array([document_vector_weighted(w2v_model, doc, word2weight) for doc in X_train_tokens])\n",
        "    X_test_w2v  = np.array([document_vector_weighted(w2v_model, doc, word2weight) for doc in X_test_tokens])\n",
        "\n",
        "    # Normalizamos\n",
        "    scaler = Normalizer(norm='l2')\n",
        "    X_train_w2v_scaled = scaler.fit_transform(X_train_w2v)\n",
        "    X_test_w2v_scaled = scaler.transform(X_test_w2v)\n",
        "\n",
        "    t_emb_w2v = round((time() - t0_emb)/60, 2)\n",
        "    mem_emb_w2v = round(get_memory() - mem0_emb, 2)\n",
        "\n",
        "    print(f\"Word2Vec listo en {t_emb_w2v} minutos.\")\n",
        "    print(f\"Memoria: {mem_emb_w2v}\")\n",
        "    print(f\"Dimensiones X_train_w2v: {X_train_w2v.shape}\")\n",
        "\n",
        "    # Guardar matrices de Word2Vec\n",
        "    np.save(ruta_train_w2v, X_train_w2v)\n",
        "    np.save(ruta_test_w2v, X_test_w2v)\n",
        "    np.save(ruta_train_w2v_scaled, X_train_w2v_scaled)\n",
        "    np.save(ruta_test_w2v_scaled, X_test_w2v_scaled)"
      ]
    },
