      "source": [
        "print(\"--- DIVISIÓN TRAIN / TEST ---\")\n",
        "\n",
        "ruta_y_train = os.path.join(drive_dir, 'y_train.npy')\n",
        "ruta_y_test = os.path.join(drive_dir, 'y_test.npy')\n",
        "ruta_indices_train = os.path.join(drive_dir, 'indices_train.npy')\n",
        "ruta_indices_test = os.path.join(drive_dir, 'indices_test.npy')\n",
        "\n",
        "# Comprobamos si el split ya está calculado y guardado\n",
        "if (os.path.exists(ruta_y_train) and os.path.exists(ruta_y_test) and\n",
        "    os.path.exists(ruta_indices_train) and os.path.exists(ruta_indices_test)):\n",
        "\n",
        "    print(\"Cargando división de Train y Test desde Drive.\")\n",
        "    y_train = np.load(ruta_y_train)\n",
        "    y_test = np.load(ruta_y_test)\n",
        "    indices_train = np.load(ruta_indices_train)\n",
        "    indices_test = np.load(ruta_indices_test)\n",
        "\n",
        "else:\n",
        "    print(\"Calculando estratificación iterativa...\")\n",
        "    np.random.seed(42)\n",
        "\n",
        "    # Creamos una matriz de índices 2D para que la librería la acepte\n",
        "    indices = np.arange(df_50k.shape[0]).reshape(-1, 1)\n",
        "\n",
        "    # Aplicamos la estratificación iterativa\n",
        "    indices_train, y_train, indices_test, y_test = iterative_train_test_split(indices, Y_50k, test_size=0.2)\n",
        "\n",
        "    # Aplanamos los índices para poder usarlos en Pandas\n",
        "    indices_train = indices_train.flatten()\n",
        "    indices_test = indices_test.flatten()\n",
        "\n",
        "    # Guardamos los índices y las etiquetas en Drive para futuras ejecuciones\n",
        "    np.save(ruta_y_train, y_train)\n",
        "    np.save(ruta_y_test, y_test)\n",
        "    np.save(ruta_indices_train, indices_train)\n",
        "    np.save(ruta_indices_test, indices_test)\n",
        "    print(\"Índices y etiquetas guardadas en Drive exitosamente.\")\n",
