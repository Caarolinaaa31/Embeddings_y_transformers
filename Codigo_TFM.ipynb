      "source": [
        "#### GloVe"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "1VIqlANV64V2",
        "outputId": "e504d2ca-603d-485e-da1c-b5e3f9add8d9"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "--- CARGANDO MATRICES GLOVE DESDE DRIVE ---\n",
            "Dimensiones X_train_glove: (375713, 100)\n"
          ]
        }
      ],
      "source": [
        "ruta_train_glove = os.path.join(drive_dir, 'X_train_glove.npy')\n",
        "ruta_test_glove = os.path.join(drive_dir, 'X_test_glove.npy')\n",
        "ruta_train_glove_scaled = os.path.join(drive_dir, 'X_train_glove_scaled.npy')\n",
        "ruta_test_glove_scaled = os.path.join(drive_dir, 'X_test_glove_scaled.npy')\n",
        "\n",
        "# Comprobamos si las matrices ya existen\n",
        "if (os.path.exists(ruta_train_glove) and\n",
        "    os.path.exists(ruta_test_glove) and\n",
        "    os.path.exists(ruta_train_glove_scaled) and\n",
        "    os.path.exists(ruta_test_glove_scaled)):\n",
        "\n",
        "    print(\"--- CARGANDO MATRICES GLOVE DESDE DRIVE ---\")\n",
        "\n",
        "    # Cargamos las matrices\n",
        "    X_train_glove = np.load(ruta_train_glove)\n",
        "    X_test_glove = np.load(ruta_test_glove)\n",
        "    X_train_glove_scaled = np.load(ruta_train_glove_scaled)\n",
        "    X_test_glove_scaled = np.load(ruta_test_glove_scaled)\n",
        "    print(f\"Dimensiones X_train_glove: {X_train_glove.shape}\")\n",
        "\n",
        "    t_emb_glove = 0.78\n",
        "    mem_emb_glove = 1840.8\n",
        "\n",
        "else:\n",
        "    print(\"--- ENTRENANDO GLOVE ---\")\n",
        "\n",
        "    t0_emb = time()\n",
        "    mem0_emb = get_memory()\n",
        "\n",
        "    # Cargar el diccionario de GloVe\n",
        "    embed_size = 100 # dimension del vector, es el modelo que he elegido\n",
        "    def get_coefs(word, *arr):\n",
        "        return word, np.asarray(arr, dtype='float32')\n",
        "    embeddings_index = dict(get_coefs(*o.rstrip().rsplit(' ')) for o in open(EMBEDDING_FILE_GLOVE, encoding='utf-8'))\n",
        "\n",
        "    # Separamos las palabras (tokens)\n",
        "    X_train_tokens_glove = [text.split() for text in X_train_clean]\n",
        "    X_test_tokens_glove = [text.split() for text in X_test_clean]\n",
        "\n",
        "    # Promediar\n",
        "    def document_vector_glove(doc_tokens):\n",
        "        valid_words = [word for word in doc_tokens if word in embeddings_index]\n",
        "        if not valid_words:\n",
        "            return np.zeros(embed_size)\n",
        "        vectors = [embeddings_index[word] for word in valid_words]\n",
        "        return np.mean(vectors, axis=0)\n",
        "\n",
        "    # Generar matrices\n",
        "    X_train_glove = np.array([document_vector_glove(doc) for doc in X_train_tokens_glove])\n",
        "    X_test_glove = np.array([document_vector_glove(doc) for doc in X_test_tokens_glove])\n",
        "\n",
        "    # Escalamos\n",
        "    scaler = Normalizer(norm='l2')\n",
        "    X_train_glove_scaled = scaler.fit_transform(X_train_glove)\n",
        "    X_test_glove_scaled = scaler.transform(X_test_glove)\n",
        "\n",
        "    t_emb_glove = round((time() - t0_emb)/60, 2)\n",
        "    mem_emb_glove = round(get_memory() - mem0_emb, 2)\n",
        "\n",
        "    print(f\"GloVe listo en {t_emb_glove} minutos.\")\n",
        "    print(f\"Memoria: {mem_emb_glove}.\")\n",
        "    print(f\"Dimensiones X_train_glove: {X_train_glove.shape}\")\n",
        "\n",
        "    # Guardar matrices de GloVe\n",
        "    np.save(ruta_train_glove, X_train_glove)\n",
        "    np.save(ruta_test_glove, X_test_glove)\n",
        "    np.save(ruta_train_glove_scaled, X_train_glove_scaled)\n",
        "    np.save(ruta_test_glove_scaled, X_test_glove_scaled)"
      ]
    },
