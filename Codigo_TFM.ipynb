      "source": [
        "print(\"--- MODELO SCIBERT CON FINE-TUNING ---\")\n",
        "\n",
        "num_cores = os.cpu_count() or 1\n",
        "\n",
        "def multi_label_metrics(predictions, labels):\n",
        "    # Eficiencia: Usamos scipy optimizado en C en lugar del puente Numpy->PyTorch->Numpy\n",
        "\n",
        "    probs = scipy.special.expit(predictions)\n",
        "    y_pred = np.zeros(probs.shape)\n",
        "    y_pred[probs >= 0.5] = 1\n",
        "\n",
        "    f1_macro = f1_score(labels, y_pred, average=\"macro\")\n",
        "    pr_auc = average_precision_score(labels, probs, average=\"macro\")\n",
        "    return {'f1_macro': f1_macro, 'pr_auc': pr_auc}\n",
        "\n",
        "def compute_metrics(p: EvalPrediction):\n",
        "    preds = p.predictions[0] if isinstance(p.predictions, tuple) else p.predictions\n",
        "    return multi_label_metrics(predictions=preds, labels=p.label_ids)\n",
        "\n",
        "\n",
        "# TOKENIZADOR\n",
        "model_name = \"allenai/scibert_scivocab_uncased\"\n",
        "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "\n",
        "def tokenize_function(examples):\n",
        "    return tokenizer(examples[\"text\"], padding=\"max_length\", truncation=True, max_length=256)\n",
        "\n",
        "test_dataset = Dataset.from_dict({\n",
        "    'text': X_test_trans,\n",
        "    'labels': y_test.astype(float).tolist()\n",
        "})\n",
        "\n",
        "tokenized_test = test_dataset.map(tokenize_function, batched=True, num_proc=num_cores)\n",
        "\n",
        "ruta_scibert = os.path.join(save_dir_base, 'scibert_matematicas_finetuned')\n",
        "\n",
        "args = TrainingArguments(\n",
        "        output_dir=ruta_scibert + \"_checkpoints\",\n",
        "        eval_strategy=\"epoch\",\n",
        "        save_strategy=\"epoch\",\n",
        "        learning_rate=2e-5,\n",
        "        per_device_train_batch_size=16, # Aumentado para mejor rendimiento\n",
        "        gradient_accumulation_steps=2,  # Simula un batch de 32 si tu GPU tiene poca VRAM\n",
        "        per_device_eval_batch_size=32,\n",
        "        num_train_epochs=4,\n",
        "        weight_decay=0.01,\n",
        "        load_best_model_at_end=True,\n",
        "        metric_for_best_model=\"f1_macro\",\n",
        "        fp16=True,\n",
        "        # OPTIMIZACIONES DE HARDWARE:\n",
        "        dataloader_num_workers=4, # Evita que la GPU espere a la CPU para recibir batches\n",
        "        torch_compile=False,\n",
        "        save_total_limit=1,       # Evita llenar el disco guardando todos los epochs intermedios\n",
        "    )\n",
        "\n",
        "# ENTRENAMIENTO\n",
        "\n",
        "if os.path.exists(ruta_scibert):\n",
        "    print(\"Modelo SciBERT Fine-Tuned encontrado en Drive.\")\n",
        "    model = AutoModelForSequenceClassification.from_pretrained(ruta_scibert)\n",
        "    tokenizer = AutoTokenizer.from_pretrained(ruta_scibert)\n",
        "    trainer = Trainer(model = model,\n",
        "                      args=args,\n",
        "                      eval_dataset=tokenized_test,\n",
        "                      processing_class = tokenizer,\n",
        "                      compute_metrics = compute_metrics)\n",
        "\n",
        "    t_mod = 77.7\n",
        "    mem_mod = 108.04\n",
        "\n",
        "else:\n",
        "    print(\"Entrenando modelo SciBERT Fine-Tuned.\")\n",
        "\n",
        "    train_dataset = Dataset.from_dict({\n",
        "        'text': X_train_trans,\n",
        "        'labels': y_train.astype(float).tolist()\n",
        "    })\n",
        "\n",
        "    tokenized_train = train_dataset.map(tokenize_function, batched=True, num_proc=num_cores)\n",
        "\n",
        "    # Carga del modelo base\n",
        "    model = AutoModelForSequenceClassification.from_pretrained(\n",
        "        model_name,\n",
        "        num_labels=29,\n",
        "        problem_type=\"multi_label_classification\"\n",
        "    )\n",
        "\n",
        "\n",
        "\n",
        "    trainer = Trainer(\n",
        "        model=model,\n",
        "        args=args,\n",
        "        train_dataset=tokenized_train,\n",
        "        eval_dataset=tokenized_test,\n",
        "        processing_class=tokenizer,\n",
        "        compute_metrics=compute_metrics\n",
        "    )\n",
        "\n",
        "    gc.collect()\n",
        "    t0_mod = time()\n",
        "    mem0_mod = get_memory()\n",
        "\n",
        "    trainer.train()\n",
        "\n",
        "    # Guardar modelo y tokenizador\n",
        "    trainer.save_model(ruta_scibert)\n",
        "    model.save_pretrained(ruta_scibert)\n",
        "    tokenizer.save_pretrained(ruta_scibert)\n",
        "\n",
        "    t_mod = round((time() - t0_mod) / 60, 2)\n",
        "    mem_mod = round(get_memory() - mem0_mod, 2)\n",
        "    print(f\"Modelo SciBERT FT guardado en Drive. Tiempo: {t_mod} min | Memoria: {mem_mod} MB\")\n",
        "\n",
        "\n",
        "# PREDICCIÓN Y EVALUACIÓN\n",
        "predicciones_brutas = trainer.predict(tokenized_test)\n",
        "logits = predicciones_brutas.predictions\n",
        "\n",
        "# Eficiencia: Evitamos mandar a Tensor y devolver a Numpy\n",
        "probs = scipy.special.expit(logits)\n",
        "y_pred_finetuned = (probs >= 0.5).astype(int)\n",
        "\n",
        "\n",
        "resultados_globales.append({\n",
        "    \"Embedding\": \"SciBERT (Fine-Tuned)\",\n",
        "    \"Modelo\": \"Red Neuronal\",\n",
        "    \"F1 Micro\": round(f1_score(y_test, y_pred_finetuned, average='micro'), 4),\n",
        "    \"F1 Macro\": round(f1_score(y_test, y_pred_finetuned, average='macro'), 4),\n",
        "    \"Accuracy\": round(accuracy_score(y_test, y_pred_finetuned), 4),\n",
        "    \"PR-AUC\": round(average_precision_score(y_test, probs, average='macro'), 4),\n",
        "    \"Tiempo (min)\": t_mod,\n",
        "    \"Memoria (MB)\": mem_mod\n",
        "    })"
      ]
    },
