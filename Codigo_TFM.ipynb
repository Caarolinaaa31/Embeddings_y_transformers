      "source": [
        "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
        "\n",
        "# Cargamos el modelo fine-tuned y su tokenizador\n",
        "model_scibert_ft = AutoModelForSequenceClassification.from_pretrained(\n",
        "    ruta_scibert,\n",
        "    output_hidden_states=True # Para poder extraer los embeddings\n",
        "    ).to(device)\n",
        "tokenizer_scibert = AutoTokenizer.from_pretrained(ruta_scibert)\n",
        "model_scibert_ft.eval()\n",
        "\n",
        "# Extraemos los embeddings usando la función existente\n",
        "X_test_scibert_ft = extract_finetuned_embeddings(X_test_trans, model_scibert_ft, tokenizer_scibert)\n",
        "\n",
        "# Visualizamos con UMAP\n",
        "visualizar_espacio_latente(\n",
        "    X=X_test_scibert_ft,\n",
        "    Y=y_test,\n",
        "    clases=clases_matematicas,\n",
        "    titulo=\"SciBERT Fine-Tuned\",\n",
        "    n_samples=500,\n",
        "    metodo='umap'\n",
        ")\n",
        "\n",
        "# Limpiamos RAM/VRAM\n",
        "del model_scibert_ft\n",
        "torch.cuda.empty_cache()"
      ]
