        "def visualizar_espacio_latente(X, Y, clases, titulo, n_samples=500, metodo='umap'):\n",
        "    \"\"\"\n",
        "    X: Matriz de embeddings (ej. X_test_w2v)\n",
        "    Y: Matriz binaria de etiquetas (y_test)\n",
        "    clases: Lista con los nombres de las categorías\n",
        "    \"\"\"\n",
        "    # Papers con solo 1 categoría\n",
        "    indices_una_etiqueta = np.where(Y.sum(axis=1) == 1)[0]\n",
        "    n_tomar = min(n_samples, len(indices_una_etiqueta))\n",
        "\n",
        "    # Seleccionar aleatoriamente\n",
        "    np.random.seed(42)\n",
        "    indices_muestra = np.random.choice(indices_una_etiqueta, size=n_tomar, replace=False)\n",
        "\n",
        "    X_muestra = X[indices_muestra]\n",
        "    Y_muestra = Y[indices_muestra]\n",
        "\n",
        "    # Traducir el vector binario [0, 1, 0...] al nombre de la clase\n",
        "    etiquetas_texto = [clases[np.argmax(fila)] for fila in Y_muestra]\n",
        "\n",
        "    # Reducción de dimensionalidad a 2D con UMAP y T-SNE\n",
        "    if metodo == 'tsne':\n",
        "        # PCA previo ayuda a t-SNE\n",
        "        reductor = TSNE(n_components=2, perplexity=30, random_state=42, init='pca', learning_rate='auto')\n",
        "    elif metodo == 'umap':\n",
        "        reductor = umap.UMAP(n_components=2, n_neighbors=15, min_dist=0.1, random_state=42)\n",
        "    else:\n",
        "        raise ValueError(\"El método debe ser 'tsne' o 'umap'\")\n",
        "\n",
        "    X_2d = reductor.fit_transform(X_muestra)\n",
        "\n",
        "    # Graficar\n",
        "    plt.figure(figsize=(12, 8))\n",
        "    sns.scatterplot(\n",
        "        x=X_2d[:, 0],\n",
        "        y=X_2d[:, 1],\n",
        "        hue=etiquetas_texto,\n",
        "        palette=\"tab20\",\n",
        "        s=80,\n",
        "        alpha=0.8,\n",
        "        edgecolor='k'\n",
        "    )\n",
        "\n",
        "    #plt.title(f\"{titulo} ({metodo.upper()})\", fontsize=14)\n",
        "    #plt.xlabel(\"Dimensión 1\")\n",
        "    #plt.ylabel(\"Dimensión 2\")\n",
        "    plt.legend(bbox_to_anchor=(1.05, 1), loc='upper left', title=\"Categorías\", fontsize=9)\n",
        "    plt.tight_layout()\n",
        "    plt.show()"
      ]
    },
