        "# ESTA CELDA HA TARDADO:\n",
        "def preprocess(text):\n",
        "    \"\"\"\n",
        "    Elimina las fórmulas matemáticas, deja solo letras y todo en minúscula.\n",
        "    \"\"\"\n",
        "    text = str(text)\n",
        "    # Eliminar ecuaciones matemáticas\n",
        "    text = re.sub(r'\\$\\$.*?\\$\\$|\\$.*?\\$', ' ', text, flags=re.DOTALL)\n",
        "    # Eliminar caracteres que no sean letras y pasar a minúscula\n",
        "    text = re.sub(r\"[^A-Za-z]+\", ' ', text).lower()\n",
        "    # Eliminar espacios extra\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "    return text\n",
        "\n",
        "def cleaning(doc):\n",
        "    \"\"\"\n",
        "    Lematización y eliminación de stopwords.\n",
        "    \"\"\"\n",
        "    txt = [token.lemma_ for token in doc if not token.is_stop]\n",
        "    if len(txt) > 2: # Si el abstract quedó muy corto, se descarta\n",
        "        return ' '.join(txt)\n",
        "    return None\n",
        "\n",
        "def preprocess_for_transformer(text):\n",
        "    \"\"\"\n",
        "    Tranformar ecuaciones en \"math_token\".\n",
        "    \"\"\"\n",
        "    text = str(text)\n",
        "    text = re.sub(r'\\$\\$.*?\\$\\$|\\$.*?\\$', 'math_token', text, flags=re.DOTALL)\n",
        "    text = re.sub(r'\\s+', ' ', text).strip()\n",
        "    return text\n",
        "\n",
        "# =====================================================================\n",
        "\n",
        "if os.path.exists(final_drive_path):\n",
        "    print(\"Los datos limpios ya está en Drive.\")\n",
        "    df_math = pd.read_csv(final_drive_path, dtype={'id': str})\n",
        "    # Preparamos una columna con todas las etiquetas escritas en lista: ['math.CO', 'cs.CG']\n",
        "    df_math['categories_list'] = df_math['categories'].apply(lambda x: str(x).split())\n",
        "    print(f\"Dimensiones: {df_math.shape}\")\n",
        "\n",
        "else:\n",
        "    print(\"Lo datos limpios no están en Drive. \")\n",
        "    math_papers = []\n",
        "\n",
        "    # Leer el archivo JSON (original) y me quedo con solo mates\n",
        "    with open(json_file_path, 'r', encoding='utf-8') as f:\n",
        "        for line in f:\n",
        "            paper = json.loads(line)\n",
        "            categories = paper['categories'].split()\n",
        "\n",
        "            # Filtramos a categorías solo matemáticas\n",
        "            if all(cat.startswith('math.') for cat in categories):\n",
        "                math_papers.append({\n",
        "                    'id': paper['id'],\n",
        "                    'categories': paper['categories'],\n",
        "                    'categories_list': categories,\n",
        "                    'abstract': paper['abstract']\n",
        "                })\n",
        "\n",
        "    df_math = pd.DataFrame(math_papers)\n",
        "\n",
        "    # Preprocesado de texto general\n",
        "    t = time()\n",
        "    nlp = spacy.load('en_core_web_sm', disable=['ner', 'parser'])\n",
        "    brief_cleaning = (preprocess(row) for row in df_math['abstract'])\n",
        "    df_math['clean'] = [\n",
        "        cleaning(doc)\n",
        "        for doc in nlp.pipe(brief_cleaning, batch_size=2000, n_process=2)\n",
        "    ]\n",
        "\n",
        "    # Preprocesado de texto para transformer\n",
        "    # df_math['abstract_transformer'] = df_math['abstract'].apply(preprocess_for_transformer)\n",
        "    transformer_cleaning = (preprocess_for_transformer(row) for row in df_math['abstract'])\n",
        "    df_math['abstract_transformer'] = [\n",
        "        cleaning(doc)\n",
        "        for doc in nlp.pipe(transformer_cleaning, batch_size=2000, n_process=2)\n",
        "    ] # CON ESTO SE OBTIENEN PEORES RESULTADOS\n",
        "\n",
        "    # Eliminar nulos y duplicados\n",
        "    df_math = df_math.dropna(subset=['clean'])\n",
        "    df_math = df_math.drop_duplicates(subset=['clean'])\n",
        "\n",
        "    # Orden de las columnas\n",
        "    df_math = df_math[['id', 'categories', 'categories_list', 'abstract', 'clean', 'abstract_transformer']]\n",
        "\n",
        "    # Guardar en Drive\n",
        "    df_math.to_csv(final_drive_path, index=False)\n",
        "\n",
        "    print(\"Archivo final guardado.\")\n",
        "    print(f\"Dimensiones de la base de datos limpia: {df_math.shape}\")\n",
        "\n",
        "# Ver resultado\n",
        "df_math.head()"
      ]
    },
