      "cell_type": "markdown",
      "metadata": {
        "id": "1hkC97jOji0Q"
      },
      "source": [
        "####SciBERT\n",
        "- Elegí SciBERT por haber sido entrenado con papers. Pero sin hacer fine-tunning los resultados no eran muy buenos."
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "collapsed": true,
        "id": "c1rNx-_W7DV_",
        "outputId": "c930687f-ce3e-4991-a8e6-3480f5a3eeeb"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "--- CARGANDO MATRICES SCIBERT DESDE DRIVE ---\n",
            "Dimensiones X_train_bert_scaled: (375713, 768)\n"
          ]
        }
      ],
      "source": [
        "ruta_train_bert = os.path.join(drive_dir, 'X_train_bert.npy')\n",
        "ruta_test_bert = os.path.join(drive_dir, 'X_test_bert.npy')\n",
        "ruta_train_bert_scaled = os.path.join(drive_dir, 'X_train_bert_scaled.npy')\n",
        "ruta_test_bert_scaled = os.path.join(drive_dir, 'X_test_bert_scaled.npy')\n",
        "\n",
        "# Comprobamos si las matrices ya existen en drive\n",
        "if (os.path.exists(ruta_train_bert) and\n",
        "    os.path.exists(ruta_test_bert) and\n",
        "    os.path.exists(ruta_train_bert_scaled) and\n",
        "    os.path.exists(ruta_test_bert_scaled)):\n",
        "\n",
        "    print(\"--- CARGANDO MATRICES SCIBERT DESDE DRIVE ---\")\n",
        "\n",
        "    # Cargamos las matrices directamente\n",
        "    X_train_bert = np.load(ruta_train_bert)\n",
        "    X_test_bert = np.load(ruta_test_bert)\n",
        "    X_train_bert_scaled = np.load(ruta_train_bert_scaled)\n",
        "    X_test_bert_scaled = np.load(ruta_test_bert_scaled)\n",
        "\n",
        "    t_emb_bert = 22.37\n",
        "    mem_emb_bert = 1739.41\n",
        "\n",
        "    print(f\"Dimensiones X_train_bert_scaled: {X_train_bert_scaled.shape}\")\n",
        "\n",
        "else:\n",
        "    print(\"--- ENTRENANDO SCIBERT ---\")\n",
        "\n",
        "    t0_emb = time()\n",
        "    mem0_emb = get_memory()\n",
        "\n",
        "    device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\") # Usar GPU si la hay\n",
        "    print(f\"Dispositivo en uso: {device}\")\n",
        "\n",
        "    # Descarga del modelo\n",
        "    model_name = \"allenai/scibert_scivocab_uncased\"\n",
        "    tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "    model_bert = AutoModel.from_pretrained(model_name).to(device)\n",
        "\n",
        "    # Ponemos 256 tokens para no saturar la RAM\n",
        "    def get_bert_embeddings(text_series, batch_size=32, max_len=256):\n",
        "        model_bert.eval()\n",
        "        embeddings = []\n",
        "        text_list = text_series.tolist()\n",
        "\n",
        "        for i in tqdm(range(0, len(text_list), batch_size), desc=\"Extrayendo...\"):\n",
        "            batch_texts = text_list[i : i + batch_size]\n",
        "\n",
        "            inputs = tokenizer(batch_texts, padding=True, truncation=True,\n",
        "                               max_length=max_len, return_tensors=\"pt\").to(device)\n",
        "\n",
        "            with torch.no_grad(): # apagar el motor del cálculo del gradiente\n",
        "                outputs = model_bert(**inputs)\n",
        "\n",
        "            # token [CLS]\n",
        "            cls_embeddings = outputs.last_hidden_state[:, 0, :].cpu().numpy().astype(np.float32) #Convertir directamente a float32 para ahorrar RAM\n",
        "            embeddings.append(cls_embeddings)\n",
        "\n",
        "            # Limpiar variables temporales de la GPU en cada iteración\n",
        "            del inputs, outputs, cls_embeddings\n",
        "            torch.cuda.empty_cache()\n",
        "\n",
        "        return np.vstack(embeddings).astype(np.float32)\n",
        "\n",
        "    print(\"\\nExtrayendo SciBERT para Entrenamiento.\")\n",
        "    X_train_bert = get_bert_embeddings(X_train_trans, batch_size=32)\n",
        "\n",
        "    print(\"\\nExtrayendo SciBERT para Test.\")\n",
        "    X_test_bert = get_bert_embeddings(X_test_trans, batch_size=32)\n",
        "\n",
        "    # Borrar el modelo\n",
        "    del model_bert\n",
        "    torch.cuda.empty_cache()\n",
        "    gc.collect() # Forzamos a Python a limpiar la RAM general\n",
        "\n",
        "    scaler = Normalizer(norm='l2')\n",
        "\n",
        "    # Forzamos a float32\n",
        "    X_train_bert_scaled = scaler.fit_transform(X_train_bert).astype(np.float32)\n",
        "    X_test_bert_scaled = scaler.transform(X_test_bert).astype(np.float32)\n",
        "\n",
        "    t_emb_bert = round((time() - t0_emb)/60, 2)\n",
        "    mem_emb_bert = round(get_memory() - mem0_emb, 2)\n",
        "    print(f\"SciBERT listo en {t_emb_bert} minutos.\")\n",
        "    print(f\"Memoria: {mem_emb_bert}\")\n",
        "    print(f\"Dimensiones X_train_bert_scaled: {X_train_bert_scaled.shape}\")\n",
        "\n",
        "    # Guardar matrices de SciBERT\n",
        "    np.save(ruta_train_bert, X_train_bert)\n",
        "    np.save(ruta_test_bert, X_test_bert)\n",
        "    np.save(ruta_train_bert_scaled, X_train_bert_scaled)\n",
        "    np.save(ruta_test_bert_scaled, X_test_bert_scaled)"
      ]
    },
