      "source": [
        "print(\"--- MODELO T5 CON FINE-TUNING ---\")\n",
        "\n",
        "def compute_metrics(p: EvalPrediction):\n",
        "    # Asegurar que tomamos los logits si predictions es una tupla\n",
        "    preds = p.predictions[0] if isinstance(p.predictions, tuple) else p.predictions\n",
        "    probs = torch.sigmoid(torch.from_numpy(preds)).numpy()\n",
        "    y_pred = (probs >= 0.5).astype(int)\n",
        "\n",
        "    return {\n",
        "        'f1_macro': f1_score(p.label_ids, y_pred, average=\"macro\"),\n",
        "        'accuracy': accuracy_score(p.label_ids, y_pred),\n",
        "        'pr_auc': average_precision_score(p.label_ids, probs, average=\"macro\")\n",
        "    }\n",
        "\n",
        "\n",
        "model_name = \"t5-small\"\n",
        "tokenizer = AutoTokenizer.from_pretrained(model_name)\n",
        "\n",
        "def tokenize_function(examples):\n",
        "    # T5 suele funcionar bien con 256 o 512 tokens.\n",
        "    return tokenizer(examples[\"text\"], padding=\"max_length\", truncation=True, max_length=256)\n",
        "\n",
        "\n",
        "df_test = pd.DataFrame({'text': X_test_trans.tolist(), 'labels': y_test.astype(float).tolist()})\n",
        "test_dataset = Dataset.from_pandas(df_test)\n",
        "tokenized_test = test_dataset.map(tokenize_function, batched=True)\n",
        "\n",
        "# ENTRENAMIENTO\n",
        "ruta_t5 = os.path.join(save_dir_base, 't5_matematicas_finetuned')\n",
        "\n",
        "args_t5 = TrainingArguments(\n",
        "        output_dir=ruta_t5 + \"_checkpoints\",\n",
        "        eval_strategy=\"epoch\",\n",
        "        save_strategy=\"epoch\",\n",
        "        learning_rate=3e-4,\n",
        "\n",
        "        # --- ACELERADORES ---\n",
        "        per_device_train_batch_size=128,\n",
        "        per_device_eval_batch_size=128,\n",
        "        eval_accumulation_steps=10,       # Vaciado de memoria en evaluación\n",
        "        dataloader_num_workers=4,         # Usa 4 núcleos de CPU para cargar datos\n",
        "        # --------------------\n",
        "\n",
        "        num_train_epochs=4,\n",
        "        weight_decay=0.01,\n",
        "        load_best_model_at_end=True,\n",
        "        metric_for_best_model=\"f1_macro\",\n",
        "        bf16=True,                        # Sigue usando bf16\n",
        "        tf32=True                         # Acelera aún más las operaciones matemáticas en GPUs Ampere (A100)\n",
        "    )\n",
        "\n",
        "if os.path.exists(ruta_t5):\n",
        "    print(\"Modelo T5 Fine-Tuned en Drive.\")\n",
        "    tokenizer = AutoTokenizer.from_pretrained(ruta_t5)\n",
        "    model_t5 = AutoModelForSequenceClassification.from_pretrained(ruta_t5)\n",
        "\n",
        "    trainer_t5 = Trainer(\n",
        "        model=model_t5,\n",
        "        args = args_t5,\n",
        "        eval_dataset=tokenized_test,\n",
        "        processing_class=tokenizer,\n",
        "        compute_metrics=compute_metrics\n",
        "    )\n",
        "\n",
        "    t_mod = 99.39\n",
        "    mem_mod = 1072.44\n",
        "\n",
        "else:\n",
        "    print(\"Entrenando modelo T5 Fine-Tuned.\")\n",
        "\n",
        "    # TOKENIZACIÓN\n",
        "    df_train = pd.DataFrame({'text': X_train_trans.tolist(), 'labels': y_train.astype(float).tolist()})\n",
        "    train_dataset = Dataset.from_pandas(df_train)\n",
        "    tokenized_train = train_dataset.map(tokenize_function, batched=True)\n",
        "\n",
        "    # HF adapta la arquitectura T5 para clasificación multietiqueta automáticamente\n",
        "    model_t5 = AutoModelForSequenceClassification.from_pretrained(\n",
        "        model_name,\n",
        "        num_labels=29,\n",
        "        problem_type=\"multi_label_classification\"\n",
        "    )\n",
        "\n",
        "    trainer_t5 = Trainer(\n",
        "        model=model_t5,\n",
        "        args=args_t5,\n",
        "        train_dataset=tokenized_train,\n",
        "        eval_dataset=tokenized_test,\n",
        "        processing_class=tokenizer,\n",
        "        compute_metrics=compute_metrics\n",
        "    )\n",
        "\n",
        "    gc.collect()\n",
        "    t0_mod = time()\n",
        "    mem0_mod = get_memory()\n",
        "\n",
        "    trainer_t5.train()\n",
        "    trainer_t5.save_model(ruta_t5)\n",
        "    model_t5.save_pretrained(ruta_t5)\n",
        "    tokenizer.save_pretrained(ruta_t5)\n",
        "    print(\"Modelo T5 guardado en Drive.\")\n",
        "\n",
        "    t_mod = round((time() - t0_mod) / 60, 2)\n",
        "    mem_mod = round(get_memory() - mem0_mod, 2)\n",
        "    print(f\"Modelo T5 FT guardado en Drive. Tiempo: {t_mod} min | Memoria: {mem_mod} MB\")\n",
        "\n",
        "\n",
        "# PREDICCIÓN Y EVALUACIÓN FINAL\n",
        "predicciones_brutas = trainer_t5.predict(tokenized_test)\n",
        "preds_finales = predicciones_brutas.predictions[0] if isinstance(predicciones_brutas.predictions, tuple) else predicciones_brutas.predictions\n",
        "\n",
        "# Convertir logits a probabilidades y luego a 1s y 0s\n",
        "probs = torch.sigmoid(torch.from_numpy(preds_finales)).numpy()\n",
        "y_pred_t5 = (probs >= 0.5).astype(int)\n",
        "\n",
        "\n",
        "resultados_globales.append({\n",
        "    \"Embedding\": \"T5 (Fine-Tuned)\",\n",
        "    \"Modelo\": \"Red Neuronal\",\n",
        "    \"F1 Micro\": round(f1_score(y_test, y_pred_t5, average='micro'), 4),\n",
        "    \"F1 Macro\": round(f1_score(y_test, y_pred_t5, average='macro'), 4),\n",
        "    \"Accuracy\": round(accuracy_score(y_test, y_pred_t5), 4),\n",
        "    \"PR-AUC\": round(average_precision_score(y_test, probs, average='macro'), 4),\n",
        "    \"Tiempo (min)\": t_mod,\n",
        "    \"Memoria (MB)\": mem_mod\n",
        "})"
      ]
    },
